<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BrainApp.Desktop.ViewModels"
             x:Class="BrainApp.Desktop.Views.ProfilesPanel">

  <Border Background="#1E1E2E" Padding="0">
    <Grid RowDefinitions="Auto,*,Auto">
      <!-- Header -->
      <Border Grid.Row="0" Background="#252535" Padding="12,10">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Profiles" FontSize="14" FontWeight="SemiBold"
                     Foreground="#E5E7EB" VerticalAlignment="Center"/>
          <Button Grid.Column="1" Command="{Binding CreateNewProfileCommand}"
                  Background="#7C3AED" Padding="8,4" FontSize="12">
            <TextBlock Text="+" Foreground="White" FontSize="16" FontWeight="Bold"/>
          </Button>
        </Grid>
      </Border>

      <!-- Profile list -->
      <ScrollViewer Grid.Row="1" Padding="8">
        <ItemsControl ItemsSource="{Binding Profiles}"
                      x:Name="ProfilesList">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Margin="0,2" Padding="10,8" CornerRadius="6" Cursor="Hand"
                      Background="#252535"
                      Tapped="OnProfileTapped">
                <Grid ColumnDefinitions="*,Auto">
                  <Grid RowDefinitions="Auto,Auto">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Ellipse Width="10" Height="10"
                               Fill="{Binding Color}"
                               VerticalAlignment="Center"/>
                      <TextBlock Text="{Binding Name}" FontSize="13"
                                 Foreground="#F9FAFB" VerticalAlignment="Center"
                                 TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4"
                                Margin="18,2,0,0">
                      <TextBlock Text="{Binding Stats.DocumentCount, StringFormat='{}{0} docs'}"
                                 FontSize="10" Foreground="#6B7280"/>
                      <TextBlock Text="·" FontSize="10" Foreground="#4B5563"/>
                      <TextBlock Text="{Binding Stats.ChunkCount, StringFormat='{}{0} chunks'}"
                                 FontSize="10" Foreground="#6B7280"/>
                    </StackPanel>
                  </Grid>
                  <Button Grid.Column="1"
                          Command="{Binding $parent[UserControl].((vm:MainWindowViewModel)DataContext).DeleteProfileCommand}"
                          CommandParameter="{Binding}"
                          Background="Transparent" Padding="6,4" Cursor="Hand"
                          VerticalAlignment="Center">
                    <TextBlock Text="×" FontSize="14" Foreground="#6B7280"/>
                  </Button>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>

      <!-- Bottom: Model status -->
      <Border Grid.Row="2" Background="#252535" Padding="12,10">
        <StackPanel Spacing="8">
          <!-- Model chip -->
          <Border Background="#2D2D3A" CornerRadius="6" Padding="8,6" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Ellipse Width="8" Height="8"
                       Fill="#10B981"
                       VerticalAlignment="Center"/>
              <TextBlock FontSize="11" Foreground="#9CA3AF"
                         VerticalAlignment="Center" Text="Qwen 3B"/>
            </StackPanel>
          </Border>

          <!-- Status indicator -->
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Ellipse Width="8" Height="8"
                     Fill="#10B981"
                     VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ModelStatusText}" FontSize="10"
                       Foreground="#6B7280" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</UserControl>